  <proof id="0">
    <assumption linenum="0">
      <raw>(∀ x (A(x) → (B(x) ∧ C(x))))</raw>
    </assumption>
    <assumption linenum="1">
      <raw>(∀ x (A(x) → ¬C(x)))</raw>
    </assumption>
    <step linenum="2">
      <raw>(A(a) → (B(a) ∧ C(a)))</raw>
      <rule>UNIVERSAL_INSTANTIATION</rule>
      <premise>0</premise>
    </step>
    <step linenum="3">
      <raw>(A(a) → ¬C(a))</raw>
      <rule>UNIVERSAL_INSTANTIATION</rule>
      <premise>1</premise>
    </step>
    <step linenum="4">
      <rule>SUBPROOF</rule>
      <premise>1</premise>
    </step>
    <step linenum="9">
      <raw>¬A(a)</raw>
      <rule>PROOF_BY_CONTRADICTION</rule>
      <premise>4</premise>
    </step>
  </proof>
  <proof id="1">
    <assumption linenum="4">
      <raw>A(a)</raw>
    </assumption>
    <step linenum="5">
      <raw>(B(a) ∧ C(a))</raw>
      <rule>MODUS_PONENS</rule>
      <premise>4</premise>
      <premise>2</premise>
    </step>
    <step linenum="6">
      <raw>C(a)</raw>
      <rule>SIMPLIFICATION</rule>
      <premise>5</premise>
    </step>
    <step linenum="7">
      <raw>¬C(a)</raw>
      <rule>MODUS_PONENS</rule>
      <premise>4</premise>
      <premise>3</premise>
    </step>
    <step linenum="8">
      <raw>⊥</raw>
      <rule>CONTRADICTION</rule>
      <premise>7</premise>
      <premise>6</premise>
    </step>
  </proof>
</bram>